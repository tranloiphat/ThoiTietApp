<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:ThoiTietApp.ViewModels"
             xmlns:models="clr-namespace:ThoiTietApp.Models"
             x:Class="ThoiTietApp.Views.MainPage"
             x:DataType="vm:MainViewModel"
             Title="Dự Báo Thời Tiết">

    <!-- Grid ngoài cùng để đặt ActivityIndicator đè lên ScrollView khi đang load -->
    <Grid>

        <ScrollView>
            <VerticalStackLayout Padding="16" Spacing="14">

                <!-- ═══ 1. THANH TÌM KIẾM ═══ -->
                <Grid ColumnDefinitions="*, Auto" ColumnSpacing="8">
                    <!-- {Binding SearchText}: lấy/ghi giá trị từ property SearchText của ViewModel -->
                    <Entry Placeholder="Nhập tên thành phố..."
                           Text="{Binding SearchText}"
                           ReturnCommand="{Binding SearchCommand}"
                           Style="{StaticResource SearchBarStyle}"
                           WidthRequest="-1"
                           HeightRequest="50"/>
                    <Button Text="Tìm"
                            Command="{Binding SearchCommand}"
                            Style="{StaticResource ButtonImp}"
                            WidthRequest="70"
                            HeightRequest="50"
                            Margin="0"
                            Grid.Column="1"/>
                </Grid>

                <!-- ═══ 2. THỜI TIẾT HIỆN TẠI ═══ -->
                <Frame Style="{StaticResource CardView}" HeightRequest="-1" Padding="16">
                    <VerticalStackLayout Spacing="6">

                        <!-- Tên thành phố -->
                        <Label Text="{Binding CityName}"
                               Style="{StaticResource LargeLabel}"
                               HorizontalOptions="Center"
                               FontAttributes="Bold"/>

                        <!-- Icon thời tiết -->
                        <Image Source="{Binding WeatherIcon}"
                               HeightRequest="80" WidthRequest="80"
                               HorizontalOptions="Center"
                               IsAnimationPlaying="True"/>

                        <!-- Nhiệt độ lớn -->
                        <Label Text="{Binding Temperature}"
                               Style="{StaticResource LabelTemperatura}"
                               FontSize="64"
                               HorizontalOptions="Center"/>

                        <!-- Mô tả (Trời quang, Mưa rào...) -->
                        <Label Text="{Binding Description}"
                               Style="{StaticResource MediumLabel}"
                               HorizontalOptions="Center"/>

                        <!-- Gió | Độ ẩm | Cảm giác — 3 cột đều nhau -->
                        <Grid ColumnDefinitions="*,*,*" Margin="0,8,0,0">
                            <VerticalStackLayout HorizontalOptions="Center">
                                <Label Text="💨 Gió" Style="{StaticResource MicroLabel}" HorizontalOptions="Center"/>
                                <Label Text="{Binding WindSpeed}" Style="{StaticResource MediumLabel}" HorizontalOptions="Center"/>
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Column="1" HorizontalOptions="Center">
                                <Label Text="💧 Độ ẩm" Style="{StaticResource MicroLabel}" HorizontalOptions="Center"/>
                                <Label Text="{Binding Humidity}" Style="{StaticResource MediumLabel}" HorizontalOptions="Center"/>
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Column="2" HorizontalOptions="Center">
                                <Label Text="🌡 Cảm giác" Style="{StaticResource MicroLabel}" HorizontalOptions="Center"/>
                                <Label Text="{Binding FeelsLike}" Style="{StaticResource MediumLabel}" HorizontalOptions="Center"/>
                            </VerticalStackLayout>
                        </Grid>

                        <!-- Nút thêm yêu thích -->
                        <!-- AddFavoriteCommand: command trong ViewModel, tự động tạo bởi [RelayCommand] -->
                        <Button Text="⭐ Thêm vào yêu thích"
                                Command="{Binding AddFavoriteCommand}"
                                Style="{StaticResource ButtonImp}"
                                Margin="0,8,0,0"/>
                    </VerticalStackLayout>
                </Frame>

                <!-- ═══ 3. DỰ BÁO 7 NGÀY ═══ -->
                <Label Text="Dự báo 7 ngày" Style="{StaticResource MediumLabel}" FontAttributes="Bold"/>

                <!-- CollectionView nằm ngang, mỗi item là 1 card ngày -->
                <CollectionView ItemsSource="{Binding DailyForecasts}" HeightRequest="120">
                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Horizontal" ItemSpacing="8"/>
                    </CollectionView.ItemsLayout>
                    <CollectionView.ItemTemplate>
                        <!-- x:DataType giúp XAML biết kiểu dữ liệu để kiểm tra lỗi lúc compile -->
                        <DataTemplate x:DataType="models:DailyForecast">
                            <Frame Style="{StaticResource CardViewHorizontal}"
                                   HeightRequest="110" WidthRequest="72" Padding="4">
                                <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="2">
                                    <Label Text="{Binding DayName}"
                                           Style="{StaticResource MicroLabel}"
                                           HorizontalOptions="Center"/>
                                    <Image Source="{Binding Icon}"
                                           HeightRequest="32" WidthRequest="32"
                                           HorizontalOptions="Center"
                                           IsAnimationPlaying="True"/>
                                    <Label Text="{Binding TempMax, StringFormat='{0:F0}°'}"
                                           Style="{StaticResource SmallLabel}"
                                           HorizontalOptions="Center"/>
                                    <Label Text="{Binding TempMin, StringFormat='{0:F0}°'}"
                                           Style="{StaticResource MicroLabel}"
                                           HorizontalOptions="Center"
                                           TextColor="Gray"/>
                                </VerticalStackLayout>
                            </Frame>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <!-- ═══ 4. THÀNH PHỐ YÊU THÍCH ═══ -->
                <Label Text="⭐ Thành phố yêu thích" Style="{StaticResource MediumLabel}" FontAttributes="Bold"/>

                <CollectionView ItemsSource="{Binding Favorites}" HeightRequest="80">
                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Horizontal" ItemSpacing="8"/>
                    </CollectionView.ItemsLayout>
                    <CollectionView.EmptyView>
                        <Label Text="Chưa có thành phố yêu thích" Style="{StaticResource SmallLabel}" TextColor="Gray"/>
                    </CollectionView.EmptyView>
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:FavoriteCity">
                            <Frame Style="{StaticResource CardView}" HeightRequest="70" Padding="8">
                                <Grid ColumnDefinitions="*, Auto" VerticalOptions="Center">
                                    <!-- Tap vào tên thành phố → load thời tiết thành phố đó -->
                                    <Label Text="{Binding CityName}"
                                           Style="{StaticResource SmallLabel}"
                                           VerticalOptions="Center">
                                        <Label.GestureRecognizers>
                                            <!-- RelativeSource: lấy command từ ViewModel cha vì đang trong DataTemplate -->
                                            <TapGestureRecognizer
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:MainViewModel}}, Path=LoadFavoriteCityCommand}"
                                                CommandParameter="{Binding .}"/>
                                        </Label.GestureRecognizers>
                                    </Label>
                                    <!-- Nút X xóa yêu thích -->
                                    <Button Text="✕"
                                            Grid.Column="1"
                                            WidthRequest="36" HeightRequest="36"
                                            Padding="0" FontSize="12"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:MainViewModel}}, Path=RemoveFavoriteCommand}"
                                            CommandParameter="{Binding .}"/>
                                </Grid>
                            </Frame>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <!-- ═══ 5. TÌM KIẾM GẦN ĐÂY ═══ -->
                <Label Text="🕐 Tìm kiếm gần đây" Style="{StaticResource MediumLabel}" FontAttributes="Bold"/>

                <CollectionView ItemsSource="{Binding RecentSearches}">
                    <CollectionView.EmptyView>
                        <Label Text="Chưa có lịch sử tìm kiếm" Style="{StaticResource SmallLabel}" TextColor="Gray"/>
                    </CollectionView.EmptyView>
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:SearchHistory">
                            <Frame Style="{StaticResource CardView}" HeightRequest="50" Margin="0,2" Padding="12,0">
                                <Grid ColumnDefinitions="*, Auto" VerticalOptions="Center">
                                    <Label Text="{Binding CityName}"
                                           Style="{StaticResource SmallLabel}"
                                           VerticalOptions="Center">
                                        <Label.GestureRecognizers>
                                            <TapGestureRecognizer
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:MainViewModel}}, Path=LoadFromHistoryCommand}"
                                                CommandParameter="{Binding .}"/>
                                        </Label.GestureRecognizers>
                                    </Label>
                                    <!-- Hiển thị thời gian tìm gần nhất -->
                                    <Label Text="{Binding SearchTime, StringFormat='{0:dd/MM HH:mm}'}"
                                           Style="{StaticResource MicroLabel}"
                                           Grid.Column="1"
                                           TextColor="Gray"
                                           VerticalOptions="Center"/>
                                </Grid>
                            </Frame>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

            </VerticalStackLayout>
        </ScrollView>

        <!-- ActivityIndicator đè lên toàn màn hình khi IsLoading = true -->
        <ActivityIndicator IsRunning="{Binding IsLoading}"
                           IsVisible="{Binding IsLoading}"
                           VerticalOptions="Center"
                           HorizontalOptions="Center"
                           Color="{StaticResource Primary}"/>

    </Grid>
</ContentPage>
